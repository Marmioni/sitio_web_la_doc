---
// NAVEGACION DEL FOOTER: cambia aqui los textos y rutas del menu inferior.
const navLinks = [
  { href: "/", label: "Inicio" },
  { href: "/biografia", label: "Biografía" },
  { href: "/bibliografia", label: "Bibliografía" },
  { href: "/blog", label: "Blog" },
  { href: "/contacto", label: "Contacto" },
];

// REDES DEL FOOTER: cambia los nombres aqui y las URL en href="#" mas abajo.
const socialLinks = ["Instagram", "YouTube", "Substack", "Amazon"];
---

<footer class="site-footer">
  <div>
    <!-- TEXTO DEL FOOTER: cambia esta frase y el nombre del autor. -->
    <p class="footer-kicker">Creadora independiente</p>
    <h2>MAR MIONI</h2>
  </div>
  <div class="footer-grid">
    <nav aria-label="Footer navigation">
      {navLinks.map((link) => <a href={link.href}>{link.label}</a>)}
    </nav>
    <div class="footer-socials">
      {socialLinks.map((link) => <a href="#" aria-label={`${link} placeholder`}>{link}</a>)}
    </div>
  </div>
  <!-- COPYRIGHT: actualiza el año, nombre y texto legal cuando corresponda. -->
  <p class="copyright">© 2026 MAR MIONI. Copyright placeholder.</p>
</footer>
