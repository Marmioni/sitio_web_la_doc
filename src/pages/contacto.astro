---
import BaseLayout from "@layouts/BaseLayout.astro";
import FragmentQuote from "@components/FragmentQuote.astro";
---

<BaseLayout title="Contacto | MAR MIONI">
  <main class="placeholder-page">
    <section class="page-hero">
      <p class="eyebrow">Escríbeme</p>
      <h1>Contacto</h1>
      <p>
        Para lecturas, entrevistas, colaboraciones, prensa o mensajes que no caben en una
        conversación normal, puedes escribir por correo o WhatsApp.
      </p>
    </section>

    <FragmentQuote text="Todo lo negativo para otro lado" tone="red" />

    <section class="coming-soon-grid" aria-label="Información de contacto">
      <article>
        <span>01</span>
        <h2>Correo</h2>
        <p>
          <a class="text-link" href="mailto:maarthamaria@gmail.com">
            maarthamaria@gmail.com
          </a>
        </p>
      </article>
      <article>
        <span>02</span>
        <h2>WhatsApp</h2>
        <p>
          <a class="text-link" href="https://wa.me/5214424219526">
            +1 (52) 4424219526
          </a>
        </p>
      </article>
    </section>
  </main>
</BaseLayout>
