---
import BaseLayout from "@layouts/BaseLayout.astro";
import FragmentQuote from "@components/FragmentQuote.astro";
import { instagramLink } from "../data/socialLinks";
---

<BaseLayout title="Contacto | MAR MIONI">
  <main class="placeholder-page">
    <section class="page-hero">
      <p class="eyebrow">Escríbeme</p>
      <h1>Contacto</h1>
      <p>
        Para lecturas, entrevistas, colaboraciones, prensa o mensajes que no caben en una
        conversación normal, escríbeme por Instagram.
      </p>
    </section>

    <FragmentQuote text="Todo lo negativo para otro lado" tone="red" />

    <section class="contact-panel" aria-label="Contacto por Instagram">
      <p class="eyebrow">Canal directo</p>
      <a class="instagram-card" href={instagramLink.url} aria-label="Contactar por Instagram">
        <span class="instagram-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" role="img">
            <rect x="3" y="3" width="18" height="18" rx="5"></rect>
            <circle cx="12" cy="12" r="4"></circle>
            <circle cx="17.5" cy="6.5" r="1"></circle>
          </svg>
        </span>
        <span>
          <strong>Instagram</strong>
          <small>@mar.mioni</small>
        </span>
      </a>
      <p>
        Todo contacto va por Instagram: mensajes, invitaciones, prensa, colaboraciones y
        pequeñas señales de vida.
      </p>
    </section>
  </main>
</BaseLayout>
