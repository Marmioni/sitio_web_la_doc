---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import FragmentQuote from "@components/FragmentQuote.astro";
import PlaceholderBox from "@components/PlaceholderBox.astro";
import SectionHeader from "@components/SectionHeader.astro";
import WorkCard from "@components/WorkCard.astro";

const works = await getCollection("books");
const media = await getCollection("media");
const books = works.filter((work) => work.data.kind === "Book");
const stories = works.filter((work) => work.data.kind === "Short Story");

// REDES SOCIALES: cambia aqui las URL reales de cada perfil.
const socialLinks = [
  { label: "Instagram", url: "https://instagram.com/yourname" },
  { label: "YouTube", url: "https://youtube.com/@yourname" },
  { label: "Substack", url: "https://marmioni.substack.com" },
  { label: "Amazon Author Page", url: "https://amazon.com/author/yourname" }
];
---

<BaseLayout title="MAR MIONI | Contemporary Literary Author">
  <main>
    <!-- HERO: cambia aqui el nombre del autor, la frase principal y el texto del retrato. -->
    <section class="hero-section">
      <div class="hero-copy reveal">
        <p class="eyebrow">Contemporary literary fiction</p>
        <h1>MAR MIONI</h1>
        <p class="hero-tagline">
         Escritora .<br />
          Storyteller.<br />
          Bienvenidos a mi aquelarre.
        </p>
      </div>
      <div class="hero-art reveal delay-1">
        <PlaceholderBox
          label="AUTHOR PORTRAIT PLACEHOLDER - replace with photo in public/images"
          shape="portrait"
          accent="teal"
        />
      </div>
    </section>

    <!-- REDES SOCIALES: reemplaza href="#" por las URL reales de Instagram, TikTok, YouTube, Substack y Amazon. -->
    <section class="social-strip" aria-label="Social links">
      {socialLinks.map((link) => <a href={link.url} aria-label={link.label}>{link.label}</a>)}
    </section>

    <!-- FRASE LITERARIA: cambia el texto del atributo text para modificar este fragmento editorial. -->
    <FragmentQuote text="JURO QUE PENSÉ TENER TODO BAJO CONTROL." tone="red" />

    <!-- LIBRO DESTACADO: cambia portada, titulo, descripcion y enlaces de compra/muestra. -->
    <section class="feature-section">
      <div>
        <PlaceholderBox label="BOOK COVER PLACEHOLDER" shape="cover" accent="yellow" />
      </div>
      <div class="feature-copy">
        <p class="eyebrow">Featured book</p>
        <h2>NEW BOOK</h2>
        <p>
          Placeholder description for the newest work: an elegant literary accident involving
          self-deception, public performance, private panic, and jokes that arrive too late to help.
        </p>
        <div class="button-row">
          <a class="button button-primary" href="#">Buy on Amazon</a>
          <a class="button button-secondary" href="#">Read Sample</a>
        </div>
      </div>
    </section>

    <!-- FRASE LITERARIA: puedes repetir, borrar o cambiar estos fragmentos entre secciones. -->
    <FragmentQuote text="You're doing the right thing." tone="teal" />

    <!-- PODCAST: cambia la imagen del arte y el src del iframe de Spotify. -->
    <section class="podcast-section">
      <div class="podcast-card">
        <PlaceholderBox label="PODCAST ARTWORK PLACEHOLDER" shape="square" accent="red" />
        <div class="spotify-embed">
          <iframe
            data-testid="embed-iframe"
            src="https://open.spotify.com/embed/show/1NoYNkEMYiEyq7HAw5H8yv?utm_source=generator&si=676e0382a7ef4028"
            width="100%"
            height="352"
            allowfullscreen
            allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
            loading="lazy"
            title="HiStORiAs-InCóMoDaS en Spotify"
          ></iframe>
        </div>
      </div>
    </section>

    <!-- ENTREVISTAS Y MEDIOS: las tarjetas vienen de src/content/media/*.json. -->
    <section class="media-section">
      <SectionHeader
        eyebrow="Press / media"
        title="Interviews & Media"
        description="Placeholder cards for interviews, cultural notes, readings, and suspiciously articulate appearances."
      />
      <div class="media-grid">
        {
          media.map((item, index) => (
            <article class="media-card">
              <PlaceholderBox label="IMAGE PLACEHOLDER" shape="wide" accent={index === 1 ? "teal" : index === 2 ? "yellow" : "red"} />
              <p>{item.data.outlet}</p>
              <h3>{item.data.title}</h3>
              <a class="text-link" href={item.data.url}>Read</a>
            </article>
          ))
        }
      </div>
    </section>

    <!-- FRASE LITERARIA: cambia este texto si quieres otro fragmento del universo del autor. -->
    <FragmentQuote text="Escribo porque de no hacerlo, el ruido adentro sería insoportable" tone="yellow" />

    <!-- OBRAS SELECCIONADAS: los libros y cuentos vienen de src/content/books/*.json. -->
    <section class="works-section">
      <SectionHeader
        eyebrow="Selected works"
        title="Books / Short Stories"
        description="A living bibliography of long disasters and compact detonations."
      />
      <div class="works-columns">
        <div>
          <h3 class="column-title">Books</h3>
          <div class="work-list">
            {books.map((work) => <WorkCard title={work.data.title} meta={work.data.year} description={work.data.description} url={work.data.url} />)}
          </div>
        </div>
        <div>
          <h3 class="column-title">Short Stories</h3>
          <div class="work-list">
            {stories.map((work) => <WorkCard title={work.data.title} meta={work.data.year} description={work.data.description} url={work.data.url} />)}
          </div>
        </div>
      </div>
    </section>

    <!-- FRASE LITERARIA: este fragmento aparece antes del formulario de newsletter. -->
    <FragmentQuote text="Bad decisions make good stories." tone="ink" />

    <!-- NEWSLETTER: cambia titular, descripcion, placeholder del email y texto del boton. No hay backend conectado todavia. -->
    <section class="newsletter-section">
      <div>
        <p class="eyebrow">Newsletter</p>
        <h2>Join the archive.</h2>
        <p>
          Placeholder description for dispatches, fragments, release notes, readings, and future
          evidence that someone was paying attention.
        </p>
      </div>
      <form class="newsletter-form">
        <label for="email">Email address</label>
        <div>
          <input id="email" type="email" placeholder="you@example.com" />
          <button class="button button-primary" type="button">Subscribe</button>
        </div>
      </form>
    </section>
  </main>
</BaseLayout>
